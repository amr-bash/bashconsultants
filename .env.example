# Copy to .env (gitignored). Never commit real keys.

# OpenAI — preview image generation (scripts/features/generate-preview-images)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic — site chat proxy and agent workflows; server-side only (Azure SWA
# app settings for /api/chat and repo Actions secrets), never exposed to the
# browser. Auth precedence: the Claude Code OAuth token is preferred and used
# by default when set; the API key is the fallback. Set one.
#   CLAUDE_CODE_OAUTH_TOKEN — from `claude setup-token` (Claude Pro/Max), preferred
#   ANTHROPIC_API_KEY       — workspace API key with a spend cap, fallback
CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Stability AI — optional alternative preview image provider (--provider stability)
STABILITY_API_KEY=your-stability-api-key-here

# Host path to your jekyll-theme-zer0 checkout for the Docker theme mount;
# defaults to ../zer0-mistakes (see docker-compose.yml)
# ZER0_MISTAKES_PATH=/path/to/zer0-mistakes
