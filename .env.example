# Copy to .env (gitignored). Never commit real keys.

# OpenAI — preview image generation (scripts/features/generate-preview-images)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic — site chat proxy and agent workflows; server-side only (Azure SWA
# app settings for /api/chat and repo Actions secrets), never exposed to the
# browser. Auth precedence: the Claude Code OAuth token is preferred and used
# by default when set; the API key is the fallback. Set one.
#   CLAUDE_CODE_OAUTH_TOKEN — from `claude setup-token` (Claude Pro/Max), preferred
#   ANTHROPIC_API_KEY       — workspace API key with a spend cap, fallback
CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Stability AI — optional alternative preview image provider (--provider stability)
STABILITY_API_KEY=your-stability-api-key-here

# PostHog — server-side REST integration (scripts/features/posthog). This is the
# PRIVATE personal API key (prefix phx_), server-side only — never the browser.
# It is separate from the public project key the site ships in _config.yml
# (posthog.api_key, phc_). Create one at https://us.posthog.com/settings/user-api-keys
POSTHOG_API_KEY=your-posthog-personal-api-key-here

# LinkedIn — company-page publisher (scripts/features/linkedin). Server-side only
# (local .env and repo Actions secrets), never exposed to the browser. The org
# URN / base URL / API version are public and have built-in defaults — set them
# only to override. Bootstrap a token at
# https://www.linkedin.com/developers/tools/oauth/token-generator with scopes
# w_organization_social r_organization_social, authorized by a page admin.
#   LINKEDIN_ACCESS_TOKEN  — 60-day access token (required)
#   LINKEDIN_REFRESH_TOKEN — optional; only issued to approved partners
#   LINKEDIN_CLIENT_ID / LINKEDIN_CLIENT_SECRET — app credentials, needed to refresh
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Non-secret overrides (defaults: org 64517157, bashconsultants.com, version 202606)
# LINKEDIN_ORG_URN=urn:li:organization:64517157
# LINKEDIN_BASE_URL=https://bashconsultants.com
# LINKEDIN_API_VERSION=202606

# Host path to your jekyll-theme-zer0 checkout for the Docker theme mount;
# defaults to ../zer0-mistakes (see docker-compose.yml)
# ZER0_MISTAKES_PATH=/path/to/zer0-mistakes
