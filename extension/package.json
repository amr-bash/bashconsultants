{
  "name": "prompt-orchestrator",
  "displayName": "Prompt Orchestrator",
  "description": "Orchestrate AI agent workflows using structured prompts from .github/prompts/",
  "version": "0.0.1",
  "publisher": "bash-consultants",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prompt-orchestrator.refreshPrompts",
        "title": "Refresh Prompts",
        "category": "Prompt Orchestrator",
        "icon": "$(refresh)"
      },
      {
        "command": "prompt-orchestrator.executePrompt",
        "title": "Execute Prompt on File",
        "category": "Prompt Orchestrator"
      },
      {
        "command": "prompt-orchestrator.review",
        "title": "Review Article",
        "category": "Prompt Orchestrator"
      },
      {
        "command": "prompt-orchestrator.refactor",
        "title": "Refactor Code",
        "category": "Prompt Orchestrator"
      },
      {
        "command": "prompt-orchestrator.test",
        "title": "Generate Tests",
        "category": "Prompt Orchestrator"
      },
      {
        "command": "prompt-orchestrator.docs",
        "title": "Generate Documentation",
        "category": "Prompt Orchestrator"
      },
      {
        "command": "prompt-orchestrator.debug",
        "title": "Debug Code",
        "category": "Prompt Orchestrator"
      }
    ],
    "configuration": {
      "title": "Prompt Orchestrator",
      "properties": {
        "promptOrchestrator.promptsDirectory": {
          "type": "string",
          "default": ".github/prompts",
          "description": "Directory containing prompt template files"
        },
        "promptOrchestrator.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh prompts when files change"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "promptOrchestratorExplorer",
          "name": "Prompt Orchestrator"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "prompt-orchestrator.refreshPrompts",
          "when": "view == promptOrchestratorExplorer",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "prompt-orchestrator.executePrompt",
          "group": "promptOrchestrator"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.1",
    "@types/vscode": "^1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bamr87/bashconsultants.git"
  },
  "license": "MIT"
}
