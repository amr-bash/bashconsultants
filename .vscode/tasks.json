// Jekyll site build tasks
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Jekyll: Serve (Docker)",
			"type": "shell",
			"command": "docker-compose",
			"args": ["up"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": true,
			"problemMatcher": [],
			"detail": "Start Jekyll site via Docker Compose"
		},
		{
			"label": "Jekyll: Serve (Local)",
			"type": "shell",
			"command": "bundle",
			"args": ["exec", "jekyll", "serve", "--config", "_config.yml,_config_dev.yml", "--livereload", "--port", "4002"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"isBackground": true,
			"problemMatcher": [],
			"detail": "Start Jekyll site locally with live reload"
		},
		{
			"label": "Jekyll: Build",
			"type": "shell",
			"command": "bundle",
			"args": ["exec", "jekyll", "build", "--config", "_config.yml,_config_dev.yml"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": [],
			"detail": "Build Jekyll site"
		},
		{
			"label": "Docker: Down",
			"type": "shell",
			"command": "docker-compose",
			"args": ["down"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"detail": "Stop Docker containers"
		}
	]
}
