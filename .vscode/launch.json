// BASH Consultants Jekyll site launch configurations
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Jekyll: Serve (Docker)",
			"type": "node-terminal",
			"request": "launch",
			"command": "docker-compose up",
			"cwd": "${workspaceFolder}",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"serverReadyAction": {
				"pattern": "Server address: (https?://[\\S]+)",
				"uriFormat": "http://localhost:4002",
				"action": "openExternally"
			}
		},
		{
			"name": "Jekyll: Serve (Local)",
			"type": "node-terminal",
			"request": "launch",
			"command": "bundle exec jekyll serve --config '_config.yml,_config_dev.yml' --livereload --port 4002",
			"cwd": "${workspaceFolder}",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"serverReadyAction": {
				"pattern": "Server address: (https?://[\\S]+)",
				"uriFormat": "http://localhost:4002",
				"action": "openExternally"
			}
		},
		{
			"name": "Jekyll: Build",
			"type": "node-terminal",
			"request": "launch",
			"command": "bundle exec jekyll build --config '_config.yml,_config_dev.yml'",
			"cwd": "${workspaceFolder}",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	]
}
