// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}"
		},
		{
			"name": "Jekyll: Serve (Docker)",
			"type": "node-terminal",
			"request": "launch",
			"command": "docker-compose up",
			"cwd": "${workspaceFolder}",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"serverReadyAction": {
				"pattern": "Server address: (https?://[\\S]+)",
				"uriFormat": "http://localhost:4002",
				"action": "openExternally"
			}
		},
		{
			"name": "Jekyll: Serve (Local)",
			"type": "node-terminal",
			"request": "launch",
			"command": "bundle exec jekyll serve --config '_config.yml,_config_dev.yml' --livereload --port 4002",
			"cwd": "${workspaceFolder}",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"serverReadyAction": {
				"pattern": "Server address: (https?://[\\S]+)",
				"uriFormat": "http://localhost:4002",
				"action": "openExternally"
			}
		},
		{
			"name": "Jekyll: Build",
			"type": "node-terminal",
			"request": "launch",
			"command": "bundle exec jekyll build --config '_config.yml,_config_dev.yml'",
			"cwd": "${workspaceFolder}",
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	],
	"compounds": [
		{
			"name": "Extension + Jekyll",
			"configurations": ["Run Extension", "Jekyll: Serve (Docker)"],
			"stopAll": true
		}
	]
}
